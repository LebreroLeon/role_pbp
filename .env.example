# Backend
APP_ENV=development
APP_DEBUG=true
# En Docker Compose usa el hostname "postgres"; en local usa "localhost"
DATABASE_URL=postgresql+asyncpg://rolepbp:rolepbp@localhost:5432/rolepbp
CHROMA_PERSIST_DIR=./chroma_data
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CORS_ORIGINS=http://localhost:5173

# Frontend (prefix VITE_ for Vite)
# Dejar vacío para usar el proxy de Vite (/api -> backend)
VITE_API_URL=
