# Backend
APP_ENV=development
APP_DEBUG=true
# En Docker Compose usa el hostname "postgres"; en local usa "localhost"
DATABASE_URL=postgresql+asyncpg://rolepbp:rolepbp@localhost:5432/rolepbp
CHROMA_PERSIST_DIR=./chroma_data
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change-me-in-production-use-long-random-string

# Frontend (prefix VITE_ for Vite)
# Dejar vacío para usar el proxy de Vite (/api -> backend)
VITE_API_URL=

# Backend uploads (Docker usa /app/campaign_uploads)
UPLOAD_DIR=./campaign_uploads
