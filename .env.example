# Backend
APP_ENV=development
APP_DEBUG=true
# En Docker Compose usa el hostname "postgres"; en local usa "localhost"
DATABASE_URL=postgresql+asyncpg://rolepbp:rolepbp@localhost:5432/rolepbp
UPLOAD_DIR=./campaign_uploads
SYSTEM_MANUALS_DIR=./data/manuals
MAX_UPLOAD_BYTES=20971520

# OpenAI â€” embeddings (RAG), Shadow Master y @asistente jugador (opcional en dev)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o-mini

# Anthropic (alternativa futura)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Acceso desde el movil (misma WiFi): abre http://TU_IP_LAN:5173 (ipconfig -> IPv4 del adaptador Ethernet/Wi-Fi).
# Deja VITE_API_URL vacio para que /api pase por el proxy de Vite (recomendado).
# Si pones VITE_API_URL=http://TU_IP_LAN:8000, anade tambien http://TU_IP_LAN:5173 a CORS_ORIGINS.
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Legacy â€” ChromaDB retirado; mantener vacÃ­o
CHROMA_PERSIST_DIR=./chroma_data

# Frontend (prefix VITE_ for Vite)
# Dejar vacÃ­o para usar el proxy de Vite (/api -> backend)
VITE_API_URL=
