# Production template — copy to your host / platform secrets (never commit real values).

# --- Backend ---
APP_ENV=production
APP_DEBUG=false
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require
UPLOAD_DIR=/data/campaign_uploads
SYSTEM_MANUALS_DIR=/data/manuals
MAX_UPLOAD_BYTES=20971520

# Required for embeddings, Shadow Master, @asistente, scene summaries
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o-mini

# Strong random string (openssl rand -hex 32)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Comma-separated origins where the SPA is served (include https://)
# Vercel example: https://rolepbp-xxx.vercel.app
CORS_ORIGINS=https://your-frontend.example.com

# --- Frontend build (Vite, set at build time in Vercel) ---
# Render API URL, no trailing slash. Example: https://rolepbp-api.onrender.com
VITE_API_URL=
